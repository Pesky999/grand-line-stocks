# Supabase project configuration for local development.
# Publishable keys and URLs identify the project and are safe for frontend use.
# Never commit private server secrets such as service-role keys, database passwords, tokens, or API secrets.

SUPABASE_PROJECT_ID=example-project-id
SUPABASE_PUBLISHABLE_KEY=example-publishable-key
SUPABASE_URL=https://example-project.supabase.co
VITE_SUPABASE_PROJECT_ID=example-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=example-publishable-key
VITE_SUPABASE_URL=https://example-project.supabase.co
